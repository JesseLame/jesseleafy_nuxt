# Nuxt runtime config for local dev and deployment
NUXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key

# Server-only secret. Never expose this in runtimeConfig.public or commit a real value.
NUXT_SUPABASE_SECRET_KEY=sb_secret_your_server_only_secret

# Optional compatibility aliases for scripts or migration:
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key
# SUPABASE_SECRET_KEY=sb_secret_your_server_only_secret
#
# Legacy fallback names are also still supported during migration:
# SUPABASE_ANON_KEY=legacy-public-anon-key
# SUPABASE_SERVICE_ROLE_KEY=legacy-server-service-role-key
